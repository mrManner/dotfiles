"3.16.0 (created: 2017/02/01 00:55:15)

map ± gT
nnoremap J <C-d>
nnoremap K <C-u>
nnoremap m :set<Space>gui=tabs,navigation<Return>
nnoremap M :set<Space>gui=notabs,nonavigation<Return>
noremap ° :tabprevious<Return>
noremap § :tabnext<Return>
set complete=hbS
set scroll=10
set visualbell
set gui=none
source! /Users/jmanner/.vimperatorrc.local

" vim: set ft=vimperator:
